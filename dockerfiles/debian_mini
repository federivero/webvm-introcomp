FROM --platform=i386 i386/debian:bookworm
ARG DEBIAN_FRONTEND=noninteractive
RUN apt-get clean && apt-get update && apt-get -y upgrade
RUN apt-get -y install apt-utils gcc \
	python3 vim unzip ruby nodejs \
	fakeroot dbus base whiptail hexedit \
	patch wamerican ucf manpages \
	file luajit make lua5.4 dialog curl \
	less cowsay netcat-openbsd sudo

# Configuración de usuarios
RUN echo 'root:password' | chpasswd
RUN useradd -m -s /bin/bash user && echo "user:password" | chpasswd
RUN useradd -m -s /bin/bash admin && echo "admin:escape123" | chpasswd

# Reemplazo de find para evitar trampas (reemplazando el binario real)
RUN mv /usr/bin/find /usr/bin/find.bak \
    && printf '#!/bin/bash\necho "Ahhh... comando find. No no no, estás haciendo trampita. Las autoridades de facultad ya fueron avisadas."\n' > /usr/bin/find \
    && chmod +x /usr/bin/find

# Alias para que grep siempre trate los archivos como texto
RUN echo "alias grep='grep --text'" >> /etc/bash.bashrc \
    && echo "alias grep='grep --text'" >> /home/user/.bashrc

# Copiamos el taller al directorio del usuario
COPY ./taller2 /home/user/taller2

# Permisos de solo lectura para el archivo de metadata
RUN chmod 111 /home/user/taller2/*/.meta \
    && chmod 444 /home/user/taller2/*/.meta/.ambiente_metadata

# Cambian todos los permisos de las carpetas para bloquearlas
RUN chmod 111 \
    /home/user/taller2 \
    /home/user/taller2/*/boveda \
    /home/user/taller2/*/laberinto \
    /home/user/taller2/*/logs_sistema \
    /home/user/taller2/*/panel_control \
    /home/user/taller2/*/sala_vacia \
    /home/user/taller2/*/servidor_web

# Configuración para actividad 3
RUN for dir in /home/user/taller2/*; do \
        if [ -f "$dir/servidor_web/validar.c" ]; then \
            gcc -o "$dir/servidor_web/validar" "$dir/servidor_web/validar.c" \
            && rm "$dir/servidor_web/validar.c" \
            && chmod 111 "$dir/servidor_web/validar"; \
        fi; \
    done

# Configuración para actividad 5
RUN chmod 400 /home/user/taller2/*/boveda/tesoro.txt

# Configuración para actividad 6
RUN for dir in /home/user/taller2/*; do \
        if [ -f "$dir/panel_control/reinicio_sistema.c" ]; then \
            gcc -o "$dir/panel_control/reinicio_sistema" "$dir/panel_control/reinicio_sistema.c" \
            && rm "$dir/panel_control/reinicio_sistema.c" \
            && chmod 000 "$dir/panel_control/reinicio_sistema"; \
        fi; \
    done

# Replace su with a PAM-free version (PAM/TTY manipulation crashes WebVM)
COPY ./dockerfiles/_su.c /tmp/_su.c
RUN gcc -o /usr/local/bin/su /tmp/_su.c \
    && chown root:root /usr/local/bin/su \
    && chmod 4111 /usr/local/bin/su

# Script c para desbloquear las carpetas con comando 'desbloquear' (ver más abajo)
COPY ./dockerfiles/_do_unlock.c /tmp/_do_unlock.c
RUN gcc -o /usr/local/bin/_do_unlock /tmp/_do_unlock.c \
    && chown root:root /usr/local/bin/_do_unlock \
    && chmod 4111 /usr/local/bin/_do_unlock

# Script de desbloqueo de carpetas (comando 'desbloquear')
COPY ./dockerfiles/desbloquear.sh /usr/local/bin/desbloquear
RUN chmod 555 /usr/local/bin/desbloquear

# Arrgelo de ownership para evitar problemas con WebVM
COPY ./dockerfiles/_fix_ownership.c /tmp/_fix_ownership.c
RUN gcc -o /usr/local/bin/_fix_ownership /tmp/_fix_ownership.c \
    && chown root:root /usr/local/bin/_fix_ownership \
    && chmod 4111 /usr/local/bin/_fix_ownership

# Damos permisos de ejecución al script de inicialización
COPY ./dockerfiles/inicializar.sh /usr/local/bin/inicializar
RUN chmod 555 /usr/local/bin/inicializar

# Side quest: verificar que el estudiante eliminó todos los basura.txt del laberinto
COPY ./dockerfiles/sidequests/verificar_basura.sh /usr/local/bin/verificar_basura
RUN chmod 555 /usr/local/bin/verificar_basura

# Side quest: verificar que el estudiante puso en 0 todos los recibos del laberinto
COPY ./dockerfiles/sidequests/verificar_recibos.sh /usr/local/bin/verificar_recibos
RUN chmod 555 /usr/local/bin/verificar_recibos

# Arreglo para el chmod: wrapper seguro que solo permite al usuario modificar sus propios archivos
COPY ./dockerfiles/_chmod.c /tmp/_chmod.c
RUN mv /bin/chmod /bin/chmod.real \
    && gcc -o /bin/chmod /tmp/_chmod.c \
    && chown root:root /bin/chmod \
    && chmod 4111 /bin/chmod \
    && chown root:root /bin/chmod.real \
    && chmod 0700 /bin/chmod.real \
    && rm /tmp/_chmod.c

# We set WORKDIR, as this gets extracted by Webvm to be used as the cwd. This is optional.
WORKDIR /home/user/taller2
# We set env, as this gets extracted by Webvm. This is optional.
ENV HOME="/home/user" TERM="xterm" USER="user" SHELL="/bin/bash" EDITOR="vim" LANG="en_US.UTF-8" LC_ALL="C"

# Entrypoint: fixes ownership lost by docker cp, then drops to user and starts bash.
# Source is compiled and deleted in one layer so it never exists in the image.
RUN printf '#include <unistd.h>\n#include <pwd.h>\n#include <grp.h>\n#include <sys/stat.h>\nint main(){\n  struct passwd *u=getpwnam("user");\n  if(!u)return 1;\n  setgid(u->pw_gid);\n  initgroups("user",u->pw_gid);\n  setuid(u->pw_uid);\n  chdir("/home/user/taller2");\n  execl("/bin/bash","/bin/bash",NULL);\n  return 1;\n}\n' > /tmp/ep.c \
    && gcc -o /entrypoint /tmp/ep.c \
    && rm /tmp/ep.c
CMD [ "/entrypoint" ]
