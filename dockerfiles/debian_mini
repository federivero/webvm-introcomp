FROM --platform=i386 i386/debian:bookworm
ARG DEBIAN_FRONTEND=noninteractive
RUN apt-get clean && apt-get update && apt-get -y upgrade
RUN apt-get -y install apt-utils gcc \
	python3 vim unzip ruby nodejs \
	fakeroot dbus base whiptail hexedit \
	patch wamerican ucf manpages \
	file luajit make lua5.4 dialog curl \
	less cowsay netcat-openbsd sudo

# Configuración de usuarios
RUN echo 'root:password' | chpasswd
RUN useradd -m -s /bin/bash user && echo "user:password" | chpasswd
RUN useradd -m -s /bin/bash admin && echo "admin:escape123" | chpasswd

# Alias para que grep siempre trate los archivos como texto
RUN echo "alias grep='grep --text'" >> /etc/bash.bashrc \
    && echo "alias grep='grep --text'" >> /home/user/.bashrc

# Replace su with a PAM-free version (PAM/TTY manipulation crashes WebVM)
COPY ./dockerfiles/_su.c /tmp/_su.c
RUN gcc -o /usr/local/bin/su /tmp/_su.c \
    && chown root:root /usr/local/bin/su \
    && chmod 4111 /usr/local/bin/su

# Arreglo para el chmod: wrapper seguro que solo permite al usuario modificar sus propios archivos
COPY ./dockerfiles/_chmod.c /tmp/_chmod.c
RUN mv /bin/chmod /bin/chmod.real \
    && gcc -o /bin/chmod /tmp/_chmod.c \
    && chown root:root /bin/chmod \
    && chmod 4111 /bin/chmod \
    && chown root:root /bin/chmod.real \
    && chmod 0700 /bin/chmod.real

# We set env, as this gets extracted by Webvm. This is optional.
ENV HOME="/home/user" TERM="xterm" USER="user" SHELL="/bin/bash" EDITOR="vim" LANG="en_US.UTF-8" LC_ALL="C"

# We set WORKDIR, as this gets extracted by Webvm to be used as the cwd.
WORKDIR /home/user

# Entrypoint: drops to user and starts bash.
RUN printf '#include <unistd.h>\n#include <pwd.h>\n#include <grp.h>\nint main(){\n  struct passwd *u=getpwnam("user");\n  if(!u)return 1;\n  setgid(u->pw_gid);\n  initgroups("user",u->pw_gid);\n  setuid(u->pw_uid);\n  chdir("/home/user");\n  execl("/bin/bash","/bin/bash",NULL);\n  return 1;\n}\n' > /tmp/ep.c \
    && gcc -o /entrypoint /tmp/ep.c \
    && rm /tmp/ep.c
CMD [ "/entrypoint" ]
